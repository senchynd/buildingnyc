---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    type: "Subway",
    title: "The most expensive subway ever built",
    description: "The Second Avenue Subway cost more per mile than any transit project in history. How did we get here, and what does it mean for the future of public transit in New York?",
    href: "/projects/second-avenue-subway",
    live: true,
  },
  {
    type: "Housing",
    title: "How New York fell 433,000 homes behind",
    description: "NYC claims to be on a record-building pace. But permits are running at a third of what's needed, and the deficit keeps growing. A look at the math — and the politics — behind New York's housing crisis.",
    href: "/projects/nyc-housing-shortage",
    live: true,
  },
  {
    type: "Infrastructure",
    title: "More coming soon",
    description: "We're working on investigations into roads, schools, and other public infrastructure. Stay tuned.",
    href: "#",
    live: false,
  }
];
---

<BaseLayout title="Building NYC — Why does it cost so much to build?">
  <section class="hero">
    <h1 class="hero-question">
      Why does it take so long <span>&</span> cost so much to build public housing and infrastructure in NYC?
    </h1>
    <p class="hero-subtitle">And how do we make it better?</p>
  </section>

  <section class="projects-section">
    <div class="project-grid">
      {projects.map((project) => (
        <a
          href={project.href}
          class={`project-card${!project.live ? ' coming-soon' : ''}`}
          aria-disabled={!project.live}
        >
          <span class="project-tag">{project.type}</span>
          <h2 class="project-title">{project.title}</h2>
          <p class="project-description">{project.description}</p>
          {project.live && (
            <span class="project-link">Read the investigation →</span>
          )}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
